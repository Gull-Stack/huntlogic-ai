---
layout: base.njk
title: Contact Hunt Logic AI | Get in Touch
description: Contact Hunt Logic AI for support, sales inquiries, or demo requests. We're here to help you hunt smarter.
---


<!-- Hero Section -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-angle"></div>
  <div class="container">
    <div class="hero-content">
      <span class="hero-label">Contact Us</span>
      <h1>Get in <span>Touch</span></h1>
      <p class="text-large">Have questions? Want a demo? We're here to help you get started with Hunt Logic AI.</p>
    </div>
  </div>
</section>

<!-- Contact Section -->
<section class="section-white">
  <div class="container">
    <div class="contact-grid">
      <!-- Contact Form -->
      <div class="slide-up">
        <span class="section-label">Send a Message</span>
        <h2>Contact Form</h2>
        <form id="contact-form" class="contact-form">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required placeholder="Your full name">

          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="your@email.com">

          <label for="phone">Phone (optional)</label>
          <input type="tel" id="phone" name="phone" placeholder="(555) 123-4567">

          <label for="subject">Subject</label>
          <select id="subject" name="subject" required>
            <option value="">Select a topic...</option>
            <option value="demo">Request a Demo</option>
            <option value="sales">Sales Inquiry</option>
            <option value="support">Technical Support</option>
            <option value="partnership">Partnership Opportunity</option>
            <option value="other">Other</option>
          </select>

          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required placeholder="How can we help you?"></textarea>

          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="slide-up stagger-2">
        <span class="section-label">Contact Info</span>
        <h2>Get in Touch</h2>

        <div class="contact-info" style="margin-top: 32px;">
          <h3>Phone</h3>
          <p>
            <a href="tel:{{ site.phone }}" style="font-size: 1.25rem; font-weight: 700; color: var(--hunter-primary);">{{ site.phone }}</a><br>
            <span style="font-size: 0.875rem;">Monday - Friday, 8am - 6pm MST</span>
          </p>

          <h3>Email</h3>
          <p>
            <a href="mailto:{{ site.email }}" style="font-size: 1.25rem; font-weight: 700; color: var(--hunter-primary);">{{ site.email }}</a><br>
            <span style="font-size: 0.875rem;">We respond within 24 hours</span>
          </p>

          <h3>Quick Links</h3>
          <ul style="list-style: none; padding: 0; margin-bottom: 24px;">
            <li style="margin-bottom: 8px;"><a href="/pricing/">Pricing & Plans</a></li>
            <li style="margin-bottom: 8px;"><a href="/technology/">Technology Overview</a></li>
            <li style="margin-bottom: 8px;"><a href="/success-stories/">Success Stories</a></li>
            <li style="margin-bottom: 8px;"><a href="/guides/">Hunting Guides</a></li>
          </ul>

          <h3>Follow Us</h3>
          <div class="social-icons" style="margin-top: 16px;">
            <a href="{{ site.socials.facebook }}" aria-label="Facebook" class="social-link" style="background: var(--hunter-primary);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="{{ site.socials.instagram }}" aria-label="Instagram" class="social-link" style="background: var(--hunter-primary);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a href="{{ site.socials.youtube }}" aria-label="YouTube" class="social-link" style="background: var(--hunter-primary);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


